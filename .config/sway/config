# Default config for sway
#
# Copy this to ~/.config/sway/config and edit it to your liking.
#
# Read `man 5 sway` for a complete reference.

### Variables
#
# Logo key. Use Mod1 for Alt.
set $mod Mod4
# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l
# Your preferred terminal emulator
# term.sh が RPM 版 wezterm を優先し、未導入時のみ Flatpak 版へフォールバック。
# （RPM は rpm-ostree でレイヤリング＆再起動が必要。移行後は自動で RPM に切り替わる）
set $term $HOME/.config/sway/scripts/term.sh
# Your preferred application launcher
# Note: pass the final command to swaymsg so that the resulting window can be opened
# on the original workspace that the command was run on.
# Recommends: rofi-wayland
set $rofi_cmd rofi \
        -terminal '$term'
# Mod+d: アプリ（.desktopファイル）のみを表示するランチャー
set $menu $rofi_cmd -show drun -modes drun

### Output configuration
#
# Default wallpaper (more resolutions are available in /usr/share/backgrounds/sway/)
# Requires: desktop-backgrounds-compat, swaybg, jxl-pixbuf-loader
output * bg $HOME/Pictures/background/2229823429-redhair_baobhansith_pc_wallpaper_2560_kabekin-Gpl2-1920x1080-MM-100.jpg fill
#
# Example configuration:
#
#   output HDMI-A-1 resolution 1920x1080 position 1920,0
#
# You can get the names of your outputs by running: swaymsg -t get_outputs

### Idle configuration
#
# Example configuration:
#
# exec swayidle -w \
#          timeout 300 'swaylock -f -c 000000' \
#          timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
#          before-sleep 'swaylock -f -c 000000'
#
# This will lock your screen after 300 seconds of inactivity, then turn off
# your displays after another 300 seconds, and turn your screens back on when
# resumed. It will also lock your screen before your computer goes to sleep.

### Input configuration
#
# Example configuration:
#
#   input "2:14:SynPS/2_Synaptics_TouchPad" {
#       dwt enabled
#       tap enabled
#       natural_scroll enabled
#       middle_emulation enabled
#   }
#
# You can get the names of your inputs by running: swaymsg -t get_inputs
# Read `man 5 sway-input` for more information about this section.

### Key bindings
#
# 各 bindsym の直前行に `#: 機能名` を置くと、keybind-rofi.py の一覧に
# その機能名が表示される（i3/Sway は行末インラインコメント不可なので前の行に書く）。
#
# Basics:
#
    # Start a terminal
    #: ターミナルを起動
    bindsym $mod+Return exec $term

    # Kill focused window
    #: ウィンドウを閉じる
    bindsym $mod+Shift+q kill

    # Start your launcher
    # launcher.sh が fuzzel(Wayland/IME対応・日本語検索可) を優先し、
    # 未導入時は rofi にフォールバックする（fuzzel は rpm-ostree でレイヤリング＆再起動が必要）。
    #: アプリランチャー（fuzzel優先・日本語検索可）
    bindsym $mod+d exec ~/.config/sway/scripts/launcher.sh

    # Mod+Tab: 同じワークスペース内のウィンドウをrofiで切り替え
    #: ウィンドウ切替（同一WS内・rofi）
    bindsym $mod+Tab exec python3 $HOME/.config/sway/scripts/sway-window-switcher.py
    # Mod+Shift+Tab: ワークスペースをrofiで切り替え
    #: ワークスペース切替（rofi）
    bindsym $mod+Shift+Tab exec python3 $HOME/.config/sway/scripts/sway-workspace-switcher.py

    # Drag floating windows by holding down $mod and left mouse button.
    # Resize them with right mouse button + $mod.
    # Despite the name, also works for non-floating windows.
    # Change normal to inverse to use left mouse button for resizing and right
    # mouse button for dragging.
    floating_modifier $mod normal

    # Reload the configuration file
    #: Sway 設定を再読み込み
    bindsym $mod+Shift+c reload

    # Exit sway (logs you out of your Wayland session)
    #: Sway を終了（確認ダイアログあり）
    bindsym $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -B 'Yes, exit sway' 'swaymsg exit'
#
# Moving around:
#
    # Move your focus around
    #: フォーカス移動 ←
    bindsym $mod+$left focus left
    #: フォーカス移動 ↓
    bindsym $mod+$down focus down
    #: フォーカス移動 ↑
    bindsym $mod+$up focus up
    #: フォーカス移動 →
    bindsym $mod+$right focus right
    # Or use $mod+[up|down|left|right]
    #: フォーカス移動 ←
    bindsym $mod+Left focus left
    #: フォーカス移動 ↓
    bindsym $mod+Down focus down
    #: フォーカス移動 ↑
    bindsym $mod+Up focus up
    #: フォーカス移動 →
    bindsym $mod+Right focus right

    # Move the focused window with the same, but add Shift
    #: ウィンドウ移動 ←
    bindsym $mod+Shift+$left move left
    #: ウィンドウ移動 ↓
    bindsym $mod+Shift+$down move down
    #: ウィンドウ移動 ↑
    bindsym $mod+Shift+$up move up
    #: ウィンドウ移動 →
    bindsym $mod+Shift+$right move right
    # Ditto, with arrow keys
    #: ウィンドウ移動 ←
    bindsym $mod+Shift+Left move left
    #: ウィンドウ移動 ↓
    bindsym $mod+Shift+Down move down
    #: ウィンドウ移動 ↑
    bindsym $mod+Shift+Up move up
    #: ウィンドウ移動 →
    bindsym $mod+Shift+Right move right
#
# Workspaces:
#
    # Switch to workspace
    #: ワークスペース 1 へ
    bindsym $mod+1 workspace number 1
    #: ワークスペース 2 へ
    bindsym $mod+2 workspace number 2
    #: ワークスペース 3 へ
    bindsym $mod+3 workspace number 3
    #: ワークスペース 4 へ
    bindsym $mod+4 workspace number 4
    #: ワークスペース 5 へ
    bindsym $mod+5 workspace number 5
    #: ワークスペース 6 へ
    bindsym $mod+6 workspace number 6
    #: ワークスペース 7 へ
    bindsym $mod+7 workspace number 7
    #: ワークスペース 8 へ
    bindsym $mod+8 workspace number 8
    #: ワークスペース 9 へ
    bindsym $mod+9 workspace number 9
    #: ワークスペース 10 へ
    bindsym $mod+0 workspace number 10
    # Move focused container to workspace
    #: ワークスペース 1 へ移動
    bindsym $mod+Shift+1 move container to workspace number 1
    #: ワークスペース 2 へ移動
    bindsym $mod+Shift+2 move container to workspace number 2
    #: ワークスペース 3 へ移動
    bindsym $mod+Shift+3 move container to workspace number 3
    #: ワークスペース 4 へ移動
    bindsym $mod+Shift+4 move container to workspace number 4
    #: ワークスペース 5 へ移動
    bindsym $mod+Shift+5 move container to workspace number 5
    #: ワークスペース 6 へ移動
    bindsym $mod+Shift+6 move container to workspace number 6
    #: ワークスペース 7 へ移動
    bindsym $mod+Shift+7 move container to workspace number 7
    #: ワークスペース 8 へ移動
    bindsym $mod+Shift+8 move container to workspace number 8
    #: ワークスペース 9 へ移動
    bindsym $mod+Shift+9 move container to workspace number 9
    #: ワークスペース 10 へ移動
    bindsym $mod+Shift+0 move container to workspace number 10
    # Note: workspaces can have any name you want, not just numbers.
    # We just use 1-10 as the default.

    # Outputs (monitors): DP-6=左(横) / DP-5=右(縦)
    # フォーカスを隣のモニターへ移動（左右・上下）
    #: 別モニタにフォーカス ←
    bindsym $mod+Ctrl+Left   focus output left
    #: 別モニタにフォーカス →
    bindsym $mod+Ctrl+Right  focus output right
    #: 別モニタにフォーカス ↑
    bindsym $mod+Ctrl+Up     focus output up
    #: 別モニタにフォーカス ↓
    bindsym $mod+Ctrl+Down   focus output down
    #: 別モニタにフォーカス ←
    bindsym $mod+Ctrl+$left  focus output left
    #: 別モニタにフォーカス →
    bindsym $mod+Ctrl+$right focus output right
    #: 別モニタにフォーカス ↑
    bindsym $mod+Ctrl+$up    focus output up
    #: 別モニタにフォーカス ↓
    bindsym $mod+Ctrl+$down  focus output down
    # フォーカス中のウィンドウを隣のモニターへ移動（左右・上下）
    #: 別モニタへ移動 ←
    bindsym $mod+Ctrl+Shift+Left   move container to output left
    #: 別モニタへ移動 →
    bindsym $mod+Ctrl+Shift+Right  move container to output right
    #: 別モニタへ移動 ↑
    bindsym $mod+Ctrl+Shift+Up     move container to output up
    #: 別モニタへ移動 ↓
    bindsym $mod+Ctrl+Shift+Down   move container to output down
    #: 別モニタへ移動 ←
    bindsym $mod+Ctrl+Shift+$left  move container to output left
    #: 別モニタへ移動 →
    bindsym $mod+Ctrl+Shift+$right move container to output right
    #: 別モニタへ移動 ↑
    bindsym $mod+Ctrl+Shift+$up    move container to output up
    #: 別モニタへ移動 ↓
    bindsym $mod+Ctrl+Shift+$down  move container to output down
    # モニター配置がズレたとき、DP-5/DP-6 の横/縦の役割を入れ替えるトグル。
    # 同一型番でEDIDシリアル無し→自動判定不能なため、見て分かる人間が手動で直す。
    # Ctrl+Alt+Del を連想する覚えやすさ＋4キー同時で誤爆防止。
    #: モニタの横/縦の役割を入れ替え
    bindsym $mod+Ctrl+Mod1+Escape exec ~/.config/sway/scripts/toggle-monitors.sh
    # キーバインド一覧を rofi で表示し、選んだコマンドを実行（cheatsheet 兼ランチャー）
    #: キーバインド一覧（このメニュー）
    bindsym $mod+Shift+slash exec python3 ~/.config/sway/scripts/keybind-rofi.py
    # 電源メニュー（ロック/サスペンド/再起動/シャットダウン/更新 等）を Rofi で表示
    #: 電源メニュー（ロック/サスペンド/電源）
    bindsym $mod+x exec ~/.config/sway/scripts/power-menu.sh
    # 設定ハブ（WiFi/BT/音/明るさ/画面/ナイトライト/電源プロファイル/通知/SS）を Rofi で表示
    #: 設定ハブ（WiFi/音/明るさ等）
    bindsym $mod+Ctrl+s exec ~/.config/sway/scripts/settings-menu.sh
    # 通知センター（履歴の確認・再表示・おやすみ切替）を Rofi で表示
    #: 通知センター（履歴/おやすみ）
    bindsym $mod+Shift+n exec ~/.config/sway/scripts/notif-center.sh
#
# Layout stuff:
#
    # You can "split" the current object of your focus with
    # $mod+b or $mod+v, for horizontal and vertical splits
    # respectively.
    #: 横に分割（左右に並べる）
    bindsym $mod+b splith
    #: 縦に分割（上下に並べる）
    bindsym $mod+v splitv

    # Switch the current container between different layout styles
    #: スタックレイアウト
    bindsym $mod+s layout stacking
    #: タブレイアウト
    bindsym $mod+w layout tabbed
    #: 分割レイアウト（横/縦）を切替
    bindsym $mod+e layout toggle split

    # Make the current focus fullscreen
    #: フルスクリーン切替
    bindsym $mod+f fullscreen

    # Toggle the current focus between tiling and floating mode
    #: フローティング切替
    bindsym $mod+Shift+space floating toggle

    # Swap focus between the tiling area and the floating area
    #: タイル/フローティング のフォーカス切替
    bindsym $mod+space focus mode_toggle

    # Move focus to the parent container
    #: 親コンテナにフォーカス
    bindsym $mod+a focus parent
    # Move focus to the child container
    #: 子コンテナにフォーカス
    bindsym $mod+Shift+a focus child
#
# Scratchpad:
#
    # Sway has a "scratchpad", which is a bag of holding for windows.
    # You can send windows there and get them back later.

    # Move the currently focused window to the scratchpad
    # （minus はズーム系と衝突するため grave=バックティックに変更）
    #: スクラッチパッドへ退避
    bindsym $mod+Shift+grave move scratchpad

    # Show the next scratchpad window or hide the focused scratchpad window.
    # If there are multiple scratchpad windows, this command cycles through them.
    # （Gmail/カレンダーPWAの引き出し表示。minus→grave に変更）
    #: スクラッチパッドを表示
    bindsym $mod+grave scratchpad show
#
# Resizing containers:
#
mode "resize" {
    # left will shrink the containers width
    # right will grow the containers width
    # up will shrink the containers height
    # down will grow the containers height
    #: [リサイズ] 幅を縮小
    bindsym $left resize shrink width 10px
    #: [リサイズ] 高さを拡大
    bindsym $down resize grow height 10px
    #: [リサイズ] 高さを縮小
    bindsym $up resize shrink height 10px
    #: [リサイズ] 幅を拡大
    bindsym $right resize grow width 10px

    # Ditto, with arrow keys
    #: [リサイズ] 幅を縮小
    bindsym Left resize shrink width 10px
    #: [リサイズ] 高さを拡大
    bindsym Down resize grow height 10px
    #: [リサイズ] 高さを縮小
    bindsym Up resize shrink height 10px
    #: [リサイズ] 幅を拡大
    bindsym Right resize grow width 10px

    # Return to default mode
    #: [リサイズ] 終了
    bindsym Return mode "default"
    #: [リサイズ] 終了
    bindsym Escape mode "default"
}
#: リサイズモードに入る
bindsym $mod+r mode "resize"

# Include configs from 3 locations:
#  - /usr/share/sway/config.d
#  - /etc/sway/config.d
#  - $XDG_CONFIG_HOME/sway/config.d ($HOME/.config/sway/config.d)
#
# If multiple directories contain the files with the same name, the later
# directory takes precedence; `$XDG_CONFIG_HOME/sway/config.d/20-swayidle.conf`
# will always be loaded instead of `/usr/share/sway/config.d/20-swayidle.conf`
# or `/etc/sway/config.d/20-swayidle.conf`
#
# This mechanism permits overriding our default configuration per-system
# (/etc) or per-user ($XDG_CONFIG_HOME) basis. Just create the file you
# want to modify/override in the higher-level directory.
#
# For example, to disable the default bar from Fedora configs, you'll need to
#     $ echo -n > "$HOME/.config/sway/config.d/90-bar.conf"
#
# Note the quoting, the $() and the arguments quoting. All the parts are equally
# important to make the magic work. And if you want to learn the secret behind
# the trick, it's all in the `wordexp(3)`.
#
include '$(/usr/libexec/sway/layered-include "/usr/share/sway/config.d/*.conf" "/etc/sway/config.d/*.conf" "${XDG_CONFIG_HOME:-$HOME/.config}/sway/config.d/*.conf")'
