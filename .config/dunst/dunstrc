# dunst 通知デザイン — Catppuccin Mocha（Waybar/Rofi と統一）
# バーが上配置なので右上・バーの下に表示。角丸＋紫フレーム。

[global]
    monitor = 0
    follow = mouse

    width = 380
    height = (0, 220)
    origin = top-right
    offset = (16, 52)          # 上のフローティングバー(高さ34+余白)の下に出す
    notification_limit = 5
    gap_size = 6

    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 0
    progress_bar_min_width = 150
    progress_bar_max_width = 360

    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 12
    horizontal_padding = 14
    text_icon_padding = 10
    frame_width = 2
    corner_radius = 14
    separator_color = frame

    sort = yes
    font = AdwaitaMono Nerd Font 11
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = end
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    enable_recursive_icon_lookup = true

    mouse_left_click = do_action, close_current
    mouse_middle_click = close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1e1e2e"
    foreground = "#a6adc8"
    frame_color = "#585b70"
    timeout = 6

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#cba6f7"
    timeout = 8

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#f38ba8"
    timeout = 0
